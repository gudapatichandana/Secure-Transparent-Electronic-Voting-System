{
  "name": "project-reg-obs-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"npx tailwindcss -i ./global.css -o ./output.css --watch\" \"expo start\"",
    "android": "concurrently \"npx tailwindcss -i ./global.css -o ./output.css --watch\" \"expo start --android\"",
    "ios": "concurrently \"npx tailwindcss -i ./global.css -o ./output.css --watch\" \"expo start --ios\"",
    "web": "concurrently \"npx tailwindcss -i ./global.css -o ./output.css --watch\" \"expo start --web\"",
    "build": "npx tailwindcss -i ./global.css -o ./output.css && npx expo export --platform web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.13.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "autoprefixer": "^10.4.24",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-camera": "^17.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-face-detector": "^13.0.2",
    "expo-file-system": "~19.0.21",
    "expo-linear-gradient": "^15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "nativewind": "^2.0.11",
    "postcss": "^8.5.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.4"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^9.2.1",
    "tailwindcss": "^3.3.2"
  }
}
